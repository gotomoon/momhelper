---
import '~/assets/styles/tailwind.css';

const cloudinaryCloudName =
  import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || import.meta.env.CLOUDINARY_CLOUD_NAME || '';
const cloudinaryUploadPreset =
  import.meta.env.PUBLIC_CLOUDINARY_UPLOAD_PRESET ||
  import.meta.env.CLOUDINARY_UPLOAD_PRESET ||
  'blog_unsigned';
const defaultAuthor = 'Mom Helper USA';
const defaultImage = '~/assets/images/default.png';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - Manage Blog Posts</title>
    <meta name="robots" content="noindex,nofollow" />
    <script src="https://upload-widget.cloudinary.com/global/all.js" type="text/javascript"></script>
    <link rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css" />
    <script src="https://uicdn.toast.com/editor/latest/toastui-editor-all.min.js"></script>
  </head>
  <body class="min-h-screen bg-gray-100 text-gray-900">
    <div id="auth-gate" class="min-h-screen flex items-center justify-center px-4">
      <div class="w-full max-w-md rounded-xl bg-white p-8 shadow-lg">
        <h1 class="mb-6 text-center text-2xl font-bold">Admin Login</h1>
        <div class="mb-4">
          <label for="admin-password" class="mb-2 block text-sm font-medium text-gray-700">Password</label>
          <input
            type="password"
            id="admin-password"
            class="w-full rounded-lg border border-gray-300 bg-white p-3 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="Enter admin password"
          />
        </div>
        <button
          onclick="authenticate()"
          class="w-full rounded-lg bg-blue-600 py-3 text-white transition hover:bg-blue-700"
        >
          Login
        </button>
        <p id="auth-error" class="mt-3 hidden text-center text-sm text-red-600">Invalid password</p>
      </div>
    </div>

    <div id="admin-dashboard" class="hidden">
      <header class="bg-white shadow">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
          <div>
            <h1 class="text-2xl font-bold text-gray-900">Blog Posts Manager</h1>
            <p class="mt-1 text-sm text-gray-500">Manage blog posts stored in `src/data/post/`.</p>
          </div>
          <div class="flex items-center gap-4">
            <a href="/" class="text-sm text-blue-700 hover:text-blue-900">View site</a>
            <button onclick="logout()" class="text-sm text-gray-600 hover:text-gray-900">Logout</button>
          </div>
        </div>
      </header>

      <main class="mx-auto max-w-7xl px-4 py-8">
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div class="flex flex-col gap-4 sm:flex-row">
            <select id="language-filter" onchange="filterPosts()" class="rounded-lg border border-gray-300 bg-white p-3">
              <option value="all">All Languages</option>
              <option value="en">English</option>
              <option value="ko">Korean</option>
            </select>
            <select id="category-filter" onchange="filterPosts()" class="rounded-lg border border-gray-300 bg-white p-3">
              <option value="all">All Categories</option>
            </select>
          </div>
          <button
            onclick="showAddForm()"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-green-600 px-6 py-3 text-white transition hover:bg-green-700"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Add New Post
          </button>
        </div>

        <div class="overflow-hidden rounded-xl bg-white shadow">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Title</th>
                  <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Category</th>
                  <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Language</th>
                  <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Author</th>
                  <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Published</th>
                  <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500">Actions</th>
                </tr>
              </thead>
              <tbody id="posts-table" class="divide-y divide-gray-200 bg-white"></tbody>
            </table>
          </div>
        </div>

        <div id="form-modal" class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-black/50 py-8">
          <div class="mx-4 max-h-[90vh] w-full max-w-6xl overflow-y-auto rounded-xl bg-white shadow-xl">
            <div class="sticky top-0 z-10 flex items-center justify-between border-b bg-white p-6">
              <h2 id="form-title" class="text-xl font-bold">Add New Post</h2>
              <button onclick="hideForm()" class="text-gray-500 hover:text-gray-700" aria-label="Close">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>

            <form id="post-form" class="space-y-6 p-6">
              <input type="hidden" id="post-filename" />
              <input type="hidden" id="original-filename" />
              <input type="hidden" id="content" />

              <div class="grid gap-6 md:grid-cols-2">
                <div class="space-y-4">
                  <h3 class="border-b pb-2 text-lg font-bold">Post Metadata</h3>

                  <div>
                    <label for="title" class="mb-2 block text-sm font-medium text-gray-700">Title *</label>
                    <input type="text" id="title" class="w-full rounded-lg border border-gray-300 p-3" required />
                  </div>

                  <div>
                    <label for="excerpt" class="mb-2 block text-sm font-medium text-gray-700">Excerpt *</label>
                    <textarea id="excerpt" class="w-full rounded-lg border border-gray-300 p-3" rows="3" required></textarea>
                  </div>

                  <div>
                    <label for="author" class="mb-2 block text-sm font-medium text-gray-700">Author *</label>
                    <input type="text" id="author" class="w-full rounded-lg border border-gray-300 p-3" value={defaultAuthor} required />
                  </div>

                  <div>
                    <label for="category" class="mb-2 block text-sm font-medium text-gray-700">Category *</label>
                    <input type="text" id="category" list="category-options" class="w-full rounded-lg border border-gray-300 p-3" required />
                    <datalist id="category-options">
                      <option value="Postpartum Care"></option>
                      <option value="Prenatal Care"></option>
                      <option value="Reviews"></option>
                    </datalist>
                  </div>

                  <div>
                    <label for="language" class="mb-2 block text-sm font-medium text-gray-700">Language *</label>
                    <select id="language" class="w-full rounded-lg border border-gray-300 p-3" required>
                      <option value="ko">Korean</option>
                      <option value="en">English</option>
                    </select>
                  </div>

                  <div>
                    <label for="tags" class="mb-2 block text-sm font-medium text-gray-700">Tags (comma-separated)</label>
                    <input type="text" id="tags" class="w-full rounded-lg border border-gray-300 p-3" placeholder="postpartum care, newborn, tips" />
                  </div>

                  <div>
                    <label for="publish-date" class="mb-2 block text-sm font-medium text-gray-700">Publish Date *</label>
                    <input type="datetime-local" id="publish-date" class="w-full rounded-lg border border-gray-300 p-3" required />
                  </div>

                  <label class="flex items-center">
                    <input type="checkbox" id="draft" class="h-4 w-4 rounded border-gray-300 text-blue-600" />
                    <span class="ml-2 text-sm text-gray-700">Save as draft</span>
                  </label>

                  <div>
                    <label for="image-url" class="mb-2 block text-sm font-medium text-gray-700">Featured Image URL</label>
                    <div
                      id="cloudinary-upload"
                      class:list={[
                        'rounded-lg border-2 border-dashed p-4 text-center transition',
                        cloudinaryCloudName ? 'cursor-pointer border-gray-300 hover:border-blue-500' : 'cursor-not-allowed border-gray-200 bg-gray-50',
                      ]}
                    >
                      <div id="upload-placeholder">
                        <svg class="mx-auto mb-2 h-8 w-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        <p class="text-sm text-gray-500">
                          {cloudinaryCloudName ? 'Click to upload with Cloudinary or paste a URL below' : 'Paste an image URL below'}
                        </p>
                      </div>
                      <img id="preview-image" class="mx-auto hidden max-h-32 rounded" alt="Preview" />
                    </div>
                    <input
                      type="text"
                      id="image-url"
                      class="mt-2 w-full rounded-lg border border-gray-300 p-3"
                      placeholder="https://example.com/image.jpg"
                    />
                  </div>
                </div>

                <div class="space-y-4">
                  <h3 class="border-b pb-2 text-lg font-bold">Post Content</h3>
                  <div>
                    <label class="mb-2 block text-sm font-medium text-gray-700">Content *</label>
                    <div id="content-editor" class="rounded-lg border border-gray-300 bg-white"></div>
                    <p class="mt-2 text-xs text-gray-500">
                      WYSIWYG is the default editor. If you need raw MDX/JSX, you can switch to Markdown mode from the editor UI.
                    </p>
                  </div>
                </div>
              </div>

              <details class="rounded-lg border p-4">
                <summary class="cursor-pointer font-bold">Advanced SEO Options</summary>
                <div class="mt-4 space-y-4">
                  <div>
                    <label for="canonical" class="mb-2 block text-sm font-medium text-gray-700">Canonical URL</label>
                    <input
                      type="url"
                      id="canonical"
                      class="w-full rounded-lg border border-gray-300 p-3"
                      placeholder="https://momhelperusa.com/post-slug"
                    />
                  </div>
                  <div>
                    <label for="meta-description" class="mb-2 block text-sm font-medium text-gray-700">Meta Description</label>
                    <textarea id="meta-description" class="w-full rounded-lg border border-gray-300 p-3" rows="2"></textarea>
                  </div>
                  <div class="flex flex-col gap-3 sm:flex-row sm:gap-6">
                    <label class="flex items-center">
                      <input type="checkbox" id="robots-index" class="h-4 w-4" checked />
                      <span class="ml-2 text-sm">Allow indexing</span>
                    </label>
                    <label class="flex items-center">
                      <input type="checkbox" id="robots-follow" class="h-4 w-4" checked />
                      <span class="ml-2 text-sm">Allow following links</span>
                    </label>
                  </div>
                </div>
              </details>

              <div class="flex flex-col gap-4 border-t pt-4 sm:flex-row">
                <button type="submit" class="flex-1 rounded-lg bg-blue-600 py-3 font-medium text-white transition hover:bg-blue-700">
                  Save Post
                </button>
                <button type="button" onclick="hideForm()" class="flex-1 rounded-lg bg-gray-300 py-3 text-gray-700 transition hover:bg-gray-400">
                  Cancel
                </button>
              </div>
            </form>
          </div>
        </div>

        <div id="delete-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4">
          <div class="w-full max-w-md rounded-xl bg-white p-6 shadow-xl">
            <h2 class="mb-4 text-xl font-bold">Delete Post?</h2>
            <p class="mb-2 text-gray-600">Are you sure you want to delete this post?</p>
            <p id="delete-post-title" class="mb-6 font-bold text-gray-900"></p>
            <p class="mb-6 text-sm text-red-600">This action cannot be undone.</p>
            <div class="flex gap-4">
              <button onclick="confirmDelete()" class="flex-1 rounded-lg bg-red-600 py-3 text-white transition hover:bg-red-700">
                Delete
              </button>
              <button onclick="hideDeleteModal()" class="flex-1 rounded-lg bg-gray-300 py-3 text-gray-700 transition hover:bg-gray-400">
                Cancel
              </button>
            </div>
          </div>
        </div>

        <div id="status-message" class="fixed bottom-4 right-4 z-50 hidden">
          <div id="status-container" class="flex items-center gap-2 rounded-lg bg-green-600 px-6 py-3 text-white shadow-lg">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span id="status-text">Saved successfully.</span>
          </div>
        </div>
      </main>
    </div>

    <script
      is:inline
      define:vars={{ cloudinaryCloudName, cloudinaryUploadPreset, defaultAuthor, defaultImage }}
    >
      let posts = [];
      let allPosts = [];
      let deleteFilename = null;
      let cloudinaryWidget = null;
      let editor = null;
      let pendingEditorContent = null;

      function authenticate() {
        const password = document.getElementById('admin-password').value;

        fetch('/api/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password }),
        })
          .then((res) => {
            if (res.ok) {
              sessionStorage.setItem('admin-auth', 'true');
              showDashboard();
            } else {
              document.getElementById('auth-error').classList.remove('hidden');
            }
          })
          .catch(() => {
            document.getElementById('auth-error').classList.remove('hidden');
          });
      }

      function logout() {
        sessionStorage.removeItem('admin-auth');
        location.reload();
      }

      function showDashboard() {
        document.getElementById('auth-gate').classList.add('hidden');
        document.getElementById('admin-dashboard').classList.remove('hidden');
        loadPosts();
        initCloudinary();
      }

      function initCloudinary() {
        if (!cloudinaryCloudName || typeof cloudinary === 'undefined') {
          return;
        }

        if (!cloudinaryWidget) {
          cloudinaryWidget = cloudinary.createUploadWidget(
            {
              cloudName: cloudinaryCloudName,
              uploadPreset: cloudinaryUploadPreset,
              sources: ['local', 'url'],
              multiple: false,
              maxFileSize: 5000000,
              folder: 'blog',
              resourceType: 'image',
            },
            (error, result) => {
              if (!error && result && result.event === 'success') {
                updateImagePreview(result.info.secure_url);
              }
            }
          );
        }

        const uploadBox = document.getElementById('cloudinary-upload');
        if (uploadBox && uploadBox.dataset.bound !== 'true') {
          uploadBox.dataset.bound = 'true';
          uploadBox.addEventListener('click', () => {
            if (cloudinaryWidget) {
              cloudinaryWidget.open();
            }
          });
        }
      }

      function initEditor() {
        if (editor) {
          return;
        }

        const container = document.getElementById('content-editor');
        if (!container) {
          return;
        }

        if (!window.toastui || !window.toastui.Editor) {
          setTimeout(initEditor, 100);
          return;
        }

        editor = new toastui.Editor({
          el: container,
          height: '480px',
          initialEditType: 'wysiwyg',
          previewStyle: 'vertical',
          usageStatistics: false,
          placeholder: 'Write your post...',
          hooks: {
            addImageBlobHook: handleEditorImageUpload,
          },
        });

        editor.on('change', () => {
          syncEditorContent();
        });

        applyPendingEditorContent();
        syncEditorContent();
      }

      function applyPendingEditorContent() {
        if (!editor || pendingEditorContent === null) {
          return;
        }

        const content = pendingEditorContent;
        pendingEditorContent = null;
        editor.setMarkdown(content || '');
      }

      function setPendingEditorContent(content) {
        pendingEditorContent = content ?? '';
        applyPendingEditorContent();
      }

      function syncEditorContent() {
        if (!editor) {
          return;
        }

        document.getElementById('content').value = editor.getMarkdown();
      }

      function setEditorContent(value) {
        setPendingEditorContent(value);
        syncEditorContent();
      }

      function getEditorContent() {
        if (editor) {
          const markdown = editor.getMarkdown();
          document.getElementById('content').value = markdown;
          return markdown;
        }

        if (pendingEditorContent !== null) {
          return pendingEditorContent;
        }

        return document.getElementById('content').value;
      }

      async function handleEditorImageUpload(blob, callback) {
        if (!cloudinaryCloudName) {
          showStatus('Cloudinary is not configured. Paste an image URL instead.', 'error');
          return false;
        }

        try {
          const url = await uploadImageToCloudinary(blob);
          callback(url, blob.name || 'image');
        } catch (error) {
          showStatus(`Image upload failed: ${error.message}`, 'error');
        }

        return false;
      }

      async function uploadImageToCloudinary(blob) {
        const formData = new FormData();
        formData.append('file', blob);
        formData.append('upload_preset', cloudinaryUploadPreset);
        formData.append('folder', 'blog');

        const response = await fetch(`https://api.cloudinary.com/v1_1/${cloudinaryCloudName}/image/upload`, {
          method: 'POST',
          body: formData,
        });

        if (!response.ok) {
          const errorText = await response.text();
          throw new Error(errorText || 'Upload failed');
        }

        const data = await response.json();
        if (!data.secure_url) {
          throw new Error('Upload failed');
        }

        return data.secure_url;
      }

      async function loadPosts() {
        try {
          const response = await fetch('/api/posts');
          if (!response.ok) {
            throw new Error('Failed to load posts');
          }

          const data = await response.json();
          allPosts = data.posts || [];
          posts = allPosts;
          populateCategoryFilter();
          renderPosts();
        } catch (error) {
          showStatus(`Failed to load posts: ${error.message}`, 'error');
        }
      }

      function populateCategoryFilter() {
        const categories = [...new Set(allPosts.map((post) => post.category).filter(Boolean))];
        const categoryFilter = document.getElementById('category-filter');

        categoryFilter.innerHTML = '<option value="all">All Categories</option>';
        categories.sort().forEach((category) => {
          const option = document.createElement('option');
          option.value = category;
          option.textContent = category;
          categoryFilter.appendChild(option);
        });
      }

      function filterPosts() {
        const languageFilter = document.getElementById('language-filter').value;
        const categoryFilter = document.getElementById('category-filter').value;

        posts = allPosts.filter((post) => {
          const languageMatch = languageFilter === 'all' || post.language === languageFilter;
          const categoryMatch = categoryFilter === 'all' || post.category === categoryFilter;
          return languageMatch && categoryMatch;
        });

        renderPosts();
      }

      function renderPosts() {
        const tbody = document.getElementById('posts-table');

        if (!posts.length) {
          tbody.innerHTML =
            '<tr><td colspan="6" class="px-6 py-12 text-center text-gray-500">No posts found. Click "Add New Post" to create one.</td></tr>';
          return;
        }

        tbody.innerHTML = posts
          .map(
            (post) => `
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4">
                  <div class="text-sm font-medium text-gray-900">${escapeHtml(post.title)}</div>
                  <div class="text-xs text-gray-500">${escapeHtml(post.filename)}</div>
                  ${
                    post.draft
                      ? '<span class="mt-1 inline-block rounded bg-yellow-100 px-2 py-1 text-xs text-yellow-800">Draft</span>'
                      : ''
                  }
                </td>
                <td class="px-6 py-4 text-sm text-gray-700">${escapeHtml(post.category || '-')}</td>
                <td class="px-6 py-4">
                  <span class="rounded px-2 py-1 text-xs ${
                    post.language === 'en' ? 'bg-blue-100 text-blue-800' : 'bg-green-100 text-green-800'
                  }">
                    ${post.language === 'en' ? 'EN' : 'KO'}
                  </span>
                </td>
                <td class="px-6 py-4 text-sm text-gray-700">${escapeHtml(post.author || '-')}</td>
                <td class="px-6 py-4 text-sm text-gray-500">${formatDate(post.publishDate)}</td>
                <td class="px-6 py-4 text-right text-sm font-medium">
                  <button onclick='editPost(${JSON.stringify(post.filename)})' class="mr-3 text-blue-600 hover:text-blue-900">Edit</button>
                  <button onclick='deletePost(${JSON.stringify(post.filename)})' class="text-red-600 hover:text-red-900">Delete</button>
                </td>
              </tr>
            `
          )
          .join('');
      }

      function showAddForm() {
        document.getElementById('form-title').textContent = 'Add New Post';
        document.getElementById('post-form').reset();
        document.getElementById('post-filename').value = '';
        document.getElementById('original-filename').value = '';
        document.getElementById('author').value = defaultAuthor;
        document.getElementById('language').value = 'ko';
        document.getElementById('robots-index').checked = true;
        document.getElementById('robots-follow').checked = true;
        clearImagePreview();

        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        document.getElementById('publish-date').value = now.toISOString().slice(0, 16);

        showFormModal();
        setEditorContent('');
      }

      function editPost(filename) {
        const post = allPosts.find((entry) => entry.filename === filename);
        if (!post) {
          return;
        }

        document.getElementById('form-title').textContent = 'Edit Post';
        document.getElementById('post-filename').value = post.filename;
        document.getElementById('original-filename').value = post.filename;
        document.getElementById('title').value = post.title || '';
        document.getElementById('excerpt').value = post.excerpt || '';
        document.getElementById('author').value = post.author || defaultAuthor;
        document.getElementById('category').value = post.category || '';
        document.getElementById('language').value = post.language || 'ko';
        document.getElementById('tags').value = (post.tags || []).join(', ');
        document.getElementById('draft').checked = Boolean(post.draft);
        document.getElementById('canonical').value = post.metadata?.canonical || '';
        document.getElementById('meta-description').value = post.metadata?.description || '';
        document.getElementById('robots-index').checked = post.metadata?.robots?.index !== false;
        document.getElementById('robots-follow').checked = post.metadata?.robots?.follow !== false;

        if (post.publishDate) {
          const date = new Date(post.publishDate);
          date.setMinutes(date.getMinutes() - date.getTimezoneOffset());
          document.getElementById('publish-date').value = date.toISOString().slice(0, 16);
        }

        showFormModal();
        setEditorContent(post.content || '');
        updateImagePreview(post.image || '');
      }

      function showFormModal() {
        document.getElementById('form-modal').classList.remove('hidden');
        document.getElementById('form-modal').classList.add('flex');

        if (!editor) {
          setTimeout(() => {
            initEditor();
          }, 50);
        }
      }

      function hideForm() {
        document.getElementById('form-modal').classList.add('hidden');
        document.getElementById('form-modal').classList.remove('flex');
      }

      function deletePost(filename) {
        const post = allPosts.find((entry) => entry.filename === filename);
        deleteFilename = filename;
        document.getElementById('delete-post-title').textContent = post?.title || filename;
        document.getElementById('delete-modal').classList.remove('hidden');
        document.getElementById('delete-modal').classList.add('flex');
      }

      function hideDeleteModal() {
        deleteFilename = null;
        document.getElementById('delete-modal').classList.add('hidden');
        document.getElementById('delete-modal').classList.remove('flex');
      }

      async function confirmDelete() {
        if (!deleteFilename) {
          return;
        }

        try {
          const response = await fetch('/api/posts/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ filename: deleteFilename }),
          });

          const data = await response.json();
          if (!response.ok) {
            throw new Error(data.error || 'Delete failed');
          }

          hideDeleteModal();
          showStatus('Post deleted successfully.', 'success');
          loadPosts();
        } catch (error) {
          showStatus(`Delete failed: ${error.message}`, 'error');
        }
      }

      document.getElementById('post-form')?.addEventListener('submit', async (event) => {
        event.preventDefault();

        const title = document.getElementById('title').value.trim();
        const filenameInput = document.getElementById('post-filename').value.trim();
        const originalFilename = document.getElementById('original-filename').value.trim();
        const tags = document
          .getElementById('tags')
          .value.split(',')
          .map((tag) => tag.trim())
          .filter(Boolean);
        const content = getEditorContent();

        const filename = filenameInput || generateFilename(title);
        const publishDate = new Date(document.getElementById('publish-date').value).toISOString();
        const canonical = document.getElementById('canonical').value.trim();
        const metaDescription = document.getElementById('meta-description').value.trim();
        const robotsIndex = document.getElementById('robots-index').checked;
        const robotsFollow = document.getElementById('robots-follow').checked;

        const frontmatter = {
          publishDate,
          author: document.getElementById('author').value.trim() || defaultAuthor,
          title,
          excerpt: document.getElementById('excerpt').value.trim(),
          image: document.getElementById('image-url').value.trim() || defaultImage,
          category: document.getElementById('category').value.trim(),
          tags,
          language: document.getElementById('language').value,
          draft: document.getElementById('draft').checked,
        };

        if (canonical || metaDescription || !robotsIndex || !robotsFollow) {
          frontmatter.metadata = {};

          if (canonical) {
            frontmatter.metadata.canonical = canonical;
          }

          if (metaDescription) {
            frontmatter.metadata.description = metaDescription;
          }

          if (!robotsIndex || !robotsFollow) {
            frontmatter.metadata.robots = {
              index: robotsIndex,
              follow: robotsFollow,
            };
          }
        }

        try {
          const response = await fetch(originalFilename ? '/api/posts/update' : '/api/posts/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              filename,
              originalFilename: originalFilename || filename,
              frontmatter,
              content,
            }),
          });

          const data = await response.json();
          if (!response.ok) {
            throw new Error(data.error || 'Save failed');
          }

          hideForm();
          showStatus('Post saved successfully.', 'success');
          loadPosts();
        } catch (error) {
          showStatus(`Save failed: ${error.message}`, 'error');
        }
      });

      document.getElementById('admin-password')?.addEventListener('keypress', (event) => {
        if (event.key === 'Enter') {
          authenticate();
        }
      });

      document.getElementById('image-url')?.addEventListener('input', (event) => {
        updateImagePreview(event.target.value.trim());
      });

      if (sessionStorage.getItem('admin-auth') === 'true') {
        showDashboard();
      }

      function updateImagePreview(url) {
        const imageInput = document.getElementById('image-url');
        const preview = document.getElementById('preview-image');
        const placeholder = document.getElementById('upload-placeholder');
        const safeUrl = url.trim();

        imageInput.value = safeUrl;

        if (!safeUrl) {
          clearImagePreview();
          return;
        }

        preview.src = safeUrl;
        preview.classList.remove('hidden');
        placeholder.classList.add('hidden');
      }

      function clearImagePreview() {
        const preview = document.getElementById('preview-image');
        const placeholder = document.getElementById('upload-placeholder');
        preview.src = '';
        preview.classList.add('hidden');
        placeholder.classList.remove('hidden');
        document.getElementById('image-url').value = '';
      }

      function generateFilename(title) {
        const slug = title
          .toLowerCase()
          .replace(/[^a-z0-9가-힣\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-')
          .trim();

        return `${slug || `post-${Date.now()}`}.mdx`;
      }

      function formatDate(value) {
        if (!value) {
          return '-';
        }

        const date = new Date(value);
        if (Number.isNaN(date.getTime())) {
          return '-';
        }

        return date.toLocaleDateString();
      }

      function escapeHtml(value) {
        return String(value || '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');
      }

      function showStatus(message, type) {
        const wrapper = document.getElementById('status-message');
        const container = document.getElementById('status-container');
        const text = document.getElementById('status-text');

        text.textContent = message;
        container.className =
          type === 'error'
            ? 'flex items-center gap-2 rounded-lg bg-red-600 px-6 py-3 text-white shadow-lg'
            : 'flex items-center gap-2 rounded-lg bg-green-600 px-6 py-3 text-white shadow-lg';

        wrapper.classList.remove('hidden');

        clearTimeout(window.__adminStatusTimeout);
        window.__adminStatusTimeout = setTimeout(() => {
          wrapper.classList.add('hidden');
        }, 4000);
      }
    </script>
  </body>
</html>
