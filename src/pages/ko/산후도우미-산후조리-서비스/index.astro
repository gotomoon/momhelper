---
import PageLayout from '~/layouts/PageLayout.astro';
import WPPageHero from '~/components/wordpress/WPPageHero.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '미국 산후도우미란 무엇인가요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '미국 산후도우미는 출산 후 가정에 방문하여 산모와 신생아를 돌보는 전문 케어 서비스입니다. 산후조리사 또는 산후관리사가 산모 회복, 신생아 케어, 모유 수유 지원, 가사 보조 등을 제공합니다.',
      },
    },
    {
      '@type': 'Question',
      name: '산후조리사와 산후관리사의 차이는 무엇인가요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '산후조리사는 산모의 회복과 신생아 케어를 전문으로 하는 직업적 명칭이며, 산후관리사는 보다 포괄적인 산후 케어와 가사 지원을 포함한 역할을 뜻합니다. 맘헬퍼USA는 두 역할을 통합한 전문 서비스를 제공합니다.',
      },
    },
    {
      '@type': 'Question',
      name: '서비스 기간은 얼마나 되나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '기본 서비스는 2주에서 8주까지 선택 가능합니다. 산모와 가족의 상황에 따라 연장 또는 조정이 가능하며, 출퇴근형과 입주형 중 선택할 수 있습니다.',
      },
    },
    {
      '@type': 'Question',
      name: '미국 어느 지역에서 서비스가 가능한가요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '로스앤젤레스(LA), 오렌지카운티, 샌디에이고, 샌프란시스코 베이 에어리어를 포함한 미국 주요 한인 밀집 지역에서 서비스를 제공합니다. 타주의 경우 별도 문의하시기 바랍니다.',
      },
    },
  ],
};

const metadata = {
  title: '미국 산후도우미 | 미국 한인 산후조리 서비스 | Mom Helper USA',
  description: '미국 한인 산모를 위한 전문 산후도우미 서비스. 경험 많은 산후조리사와 산후관리사가 산모와 신생아를 안전하게 케어합니다.',
  robots: { index: true, follow: true },
  structuredData: faqSchema,
};
---

<PageLayout metadata={metadata}>
  <!-- Hero Section -->
  <WPPageHero title="미국 산후도우미 서비스" />

  <!-- SEO Intro Sections -->
  <section class="py-16 md:py-20 bg-gray-50 dark:bg-slate-900/60">
    <div class="container mx-auto px-4 max-w-6xl">

      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-[#262f71] dark:text-white">미국 산후도우미란?</h2>
      <div class="mb-8" style="height: 4px; background-color: #D37643; width: 100px;"></div>
      <p class="text-gray-700 dark:text-gray-300 text-lg leading-relaxed mb-4">
        미국 산후도우미는 출산 후 가정을 방문하여 산모와 신생아를 전문적으로 돌보는 케어 서비스입니다. 한국의 산후조리원과 달리, 미국에서는 산후관리사가 직접 가정을 방문하여 산모의 회복과 신생아 케어를 지원합니다.
      </p>
      <p class="text-gray-700 dark:text-gray-300 text-lg leading-relaxed">
        맘헬퍼USA의 전문 산후조리사는 산모 케어, 신생아 케어, 모유 수유 지원, 산후 영양식 준비 등 산모와 가족에게 꼭 필요한 서비스를 제공합니다.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold mt-16 mb-4 text-[#262f71] dark:text-white">전문 산후조리사와 함께하는 산후 케어</h2>
      <div class="mb-8" style="height: 4px; background-color: #D37643; width: 100px;"></div>
      <p class="text-gray-700 dark:text-gray-300 text-lg leading-relaxed mb-4">
        교육과 현장 경험을 갖춘 전문 산후조리사가 산모의 빠른 회복을 돕습니다. 출산 직후의 신체 회복, 신생아와의 애착 형성, 모유 수유 지원까지 단계별 postpartum care를 제공합니다.
      </p>
      <p class="text-gray-700 dark:text-gray-300 text-lg leading-relaxed">
        각 산모의 건강 상태와 가정 환경에 맞게 서비스를 조정하여, newborn care와 breastfeeding support까지 맞춤형으로 지원합니다.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold mt-16 mb-4 text-[#262f71] dark:text-white">산후관리사가 필요한 이유</h2>
      <div class="mb-8" style="height: 4px; background-color: #D37643; width: 100px;"></div>
      <p class="text-gray-700 dark:text-gray-300 text-lg leading-relaxed mb-4">
        미국에서 출산한 한인 산모에게는 전문 산후관리사의 도움이 특히 중요합니다. 가족과 멀리 떨어져 있는 환경에서 산후 회복에 집중하려면 믿을 수 있는 전문가의 지원이 필수입니다.
      </p>
      <ul class="list-disc list-inside space-y-2 text-gray-700 dark:text-gray-300 text-lg mb-4">
        <li>출산 후 '산후풍' 예방을 위한 올바른 산후조리</li>
        <li>한국식 산후 영양식 준비와 산모 건강 관리</li>
        <li>신생아 돌봄 교육과 수유 리듬 형성 지원</li>
        <li>산모의 정서적 안정과 산후우울 예방</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold mt-16 mb-4 text-[#262f71] dark:text-white">Mom Helper USA가 특별한 이유</h2>
      <div class="mb-8" style="height: 4px; background-color: #D37643; width: 100px;"></div>
      <p class="text-gray-700 dark:text-gray-300 text-lg leading-relaxed mb-4">
        맘헬퍼USA는 원장님의 직접적인 산후 경험에서 시작된 서비스입니다. 직접 산후풍을 경험하고 제대로 된 산후조리의 중요성을 깨달은 후, 미국 한인 산모들을 위한 전문 서비스를 시작했습니다.
      </p>
      <p class="text-gray-700 dark:text-gray-300 text-lg leading-relaxed mb-6">
        고객 후기와 10년 이상의 서비스 경험이 말해주듯, 맘헬퍼USA는 신뢰와 전문성으로 수백 명의 한인 산모를 도왔습니다.
      </p>
      <a href="/ko/about" class="inline-block text-[#D37643] font-semibold underline hover:opacity-80">원장님 이야기 자세히 보기 →</a>
    </div>
  </section>

  <!-- Basic Services Section -->
  <section class="py-16 md:py-20 bg-white dark:bg-slate-900">
    <div class="container mx-auto px-4 max-w-6xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-gray-800 dark:text-white">기본 서비스</h2>
      <div class="mb-6" style="height: 4px; background-color: #D37643; width: 100px;"></div>
      <p class="text-base md:text-lg text-gray-700 dark:text-gray-300 font-semibold mb-12">
        가정의 상황에 따라 서비스가 다를 수 있습니다.
      </p>

      <h3 class="text-xl md:text-2xl font-bold mb-8" style="color: #d37643;">산후조리 서비스</h3>

      <!-- Maternal Care & Newborn Care -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <!-- Maternal Care -->
        <div>
          <img src="/images/mom-holding-baby.webp" alt="산모 케어" class="w-full h-auto rounded-lg mb-6" loading="lazy" decoding="async" />
          <h4 class="text-lg font-bold text-gray-800 dark:text-white mb-4">산모 케어</h4>
          <ul class="list-disc list-inside space-y-2 text-gray-700 dark:text-gray-300">
            <li>출산 직후의 젖몸살 유방 마사지</li>
            <li>출산후 치유 지원 (회음부 통증완화 및 상처회복 촉진을 위한 좌욕)</li>
            <li>마사지 또는 산후체조 관리 지원, 정서지원</li>
            <li>산모 위생 관리, 영양 관리,식사 준비 / 주방 청결유지</li>
          </ul>
        </div>

        <!-- Newborn Care -->
        <div>
          <img src="/images/baby-hand.webp" alt="신생아 케어" class="w-full h-auto rounded-lg mb-6" loading="lazy" decoding="async" />
          <h4 class="text-lg font-bold text-gray-800 dark:text-white mb-4">신생아 케어</h4>
          <ul class="list-disc list-inside space-y-2 text-gray-700 dark:text-gray-300">
            <li>신생아 일지 작성 및 관리(신생아 대소변 / 수유상태 등)</li>
            <li>수유 및 취침주기 관리, 기타 어드바이스 지원</li>
            <li>신생아 목욕과 배꼽관리, 신생아 마사지, 옷 갈아 입히기</li>
            <li>아기와 함께 외출시 동행하거나 필요시 간단한 가사 도움</li>
          </ul>
        </div>
      </div>

      <!-- Family Care / Housekeeping -->
      <h4 class="text-lg font-bold text-gray-800 dark:text-white mb-6">가족케어 / 가사 서비스</h4>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
        <div>
          <img src="/images/가사도우미-요리-1395.webp" alt="가사도우미 요리" class="w-full h-auto rounded-lg" loading="lazy" decoding="async" />
        </div>
        <div>
          <p class="text-gray-700 dark:text-gray-300 font-semibold mb-4">
            관리사님의 주 업무는 산모와 신생아를 돌보는 것입니다.
          </p>
          <p class="text-gray-700 dark:text-gray-300 mb-4">아기 아빠가 출장중일때 큰 아이를 챙깁니다.</p>
          <ul class="list-disc list-inside space-y-2 text-gray-700 dark:text-gray-300 mb-4">
            <li>
              유치원 등/하원 시키기 (라이드불가), 식사 및 간식 챙기기, 간단히 씻기기 (손씻기 및 세수), 장난감 정리
            </li>
          </ul>
          <p class="text-gray-700 dark:text-gray-300"><strong>상황에 따라서 업무는 조금씩 변경됩니다.</strong></p>
        </div>
      </div>

      <div class="bg-gray-50 dark:bg-slate-800 p-6 rounded-lg mb-12">
        <p class="text-gray-700 dark:text-gray-300 font-semibold mb-4">
          관리사님은 산후 조력자로서 일정부분의 가사서비스만 제공합니다.
        </p>
        <ul class="list-disc list-inside space-y-2 text-gray-700 dark:text-gray-300">
          <li>산모와 아기의 건강 상태에 따라 서비스 내용은 바뀔 수 있고 생략될 수도 있습니다.</li>
          <li>
            산모와 신생아를 제외한 다른 가족의 반찬, 집안 전체 청소, 가족들의 빨래세탁, 이불빨래, 많은 양의 다림질, 김치
            담그기, 손님 접대, 도시락 챙기기등 산후조리와 직접적으로 관련이 없는 가사일은 지원하지 않습니다.
          </li>
          <li>산후조리와 직접적으로 관련이 없는 가사일을 요구시에는 추가 요금이 발생할 수 있습니다.</li>
        </ul>
      </div>

      <!-- Basic Service Recipients -->
      <h3 class="text-xl md:text-2xl font-bold mb-6" style="color: #d37643;">기본 서비스 대상자</h3>
      <p class="text-gray-700 dark:text-gray-300 mb-6">산모, 남편, 신생아가 서비스 대상자에 해당됩니다.</p>
      <p class="text-gray-700 dark:text-gray-300 mb-6">
        만일 동거 가족이 있는 경우 다음과 같이 추가요금이 매일 발생할 수 있으며 서비스 요금에 포함되지 않습니다.
      </p>

      <!-- Pricing Table -->
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-gray-700 dark:text-gray-200">
          <thead>
            <tr class="text-white" style="background-color: #d37643;">
              <th class="p-4 text-left font-semibold">Title</th>
              <th class="p-4 text-left font-semibold border-l border-white/30">출퇴근</th>
              <th class="p-4 text-left font-semibold border-l border-white/30">입주</th>
            </tr>
          </thead>
          <tbody class="bg-gray-50 dark:bg-slate-800">
            <tr class="border-b border-gray-200 dark:border-slate-700">
              <td class="p-4">1. 기본 가족 외 1 명</td>
              <td class="p-4 border-l border-gray-200 dark:border-slate-700">$10</td>
              <td class="p-4 border-l border-gray-200 dark:border-slate-700">$20</td>
            </tr>
            <tr class="border-b border-gray-200 dark:border-slate-700">
              <td class="p-4">2. 학령기 자녀 1명 (초등학생~고등학생)</td>
              <td class="p-4 border-l border-gray-200 dark:border-slate-700">$5</td>
              <td class="p-4 border-l border-gray-200 dark:border-slate-700">$10</td>
            </tr>
            <tr class="border-b border-gray-200 dark:border-slate-700">
              <td class="p-4">3. 미취학 어린이 1명</td>
              <td class="p-4 border-l border-gray-200 dark:border-slate-700">$10</td>
              <td class="p-4 border-l border-gray-200 dark:border-slate-700">$20</td>
            </tr>
            <tr class="border-b border-gray-200 dark:border-slate-700">
              <td class="p-4">4. 쌍둥이/다둥이</td>
              <td class="p-4 border-l border-gray-200 dark:border-slate-700">$20</td>
              <td class="p-4 border-l border-gray-200 dark:border-slate-700">$40</td>
            </tr>
            <tr>
              <td class="p-4">5. 주말/공휴일 근무</td>
              <td class="p-4 border-l border-gray-200 dark:border-slate-700"
                >추가 금액이 발생하지 않고 날짜로 계산합니다</td
              >
              <td class="p-4 border-l border-gray-200 dark:border-slate-700"
                >추가 금액이 발생하지 않고 날짜로 계산합니다</td
              >
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Service Reservation Section -->
  <section class="py-16 md:py-20 bg-gray-50 dark:bg-slate-900/60">
    <div class="container mx-auto px-4 max-w-6xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-[#262f71] dark:text-white">서비스 예약</h2>
      <div class="mb-8" style="height: 4px; background-color: #D37643; width: 100px;"></div>

      <div class="space-y-6 text-gray-700 dark:text-gray-300">
        <p class="font-bold">
          온라인 예약 서비스를 이용하여 신청하시고, 예약금 결제를 하시면 온라인 예약이 확정됩니다.
        </p>
        <ul class="list-disc list-inside space-y-2">
          <li>원장님과 상담하신 후에 산모님께 맞는 형태로 산후 조리 서비스를 계약하실 수 있습니다.</li>
          <li>예약금은 서비스 이용 금액에 포함되지 않습니다.</li>
          <li>서비스 이용 금액은 산후 관리사님께 직접 지불해 주시면 됩니다.</li>
          <li>타주의 경우 왕복 비행기 티켓을 고객님께서 전액 부담하셔야 합니다.</li>
          <li>
            산모님이 예약을 하실 때에 맘헬퍼USA 에서 여유있게 스케줄을 만들겠지만, 예약 시 다시 한번 스케줄을 확인해
            주시길 부탁드립니다.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Service Reservation Button Section -->
  <section class="py-12 bg-gray-50 dark:bg-slate-900/60">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center">
        <a
          href="/ko/서비스-신청하기"
          class="inline-block text-white font-bold uppercase px-6 py-3.5 rounded-full hover:opacity-90 transition-opacity duration-300"
          style="background-color: #D37643; font-size: 14px; border-radius: 60px;"
        >
          서비스 신청하기
        </a>
      </div>
      <div
        class="mt-8 mb-4"
        style="height: 4px; background-color: #D37643; width: 100px; margin-left: auto; margin-right: auto;"
      >
      </div>
      <p class="text-center font-bold text-gray-800 dark:text-white mt-6">
        신청하시기 전에 먼저 이용약관을 확인해 주세요.
      </p>
    </div>
  </section>

  <!-- Service Fees Section -->
  <section class="py-16 md:py-20 bg-gray-50 dark:bg-slate-900/60">
    <div class="container mx-auto px-4 max-w-6xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-center text-[#262f71] dark:text-white">서비스 이용요금</h2>
      <div class="mb-8 mx-auto" style="height: 4px; background-color: #D37643; width: 100px;"></div>

      <div class="space-y-6 text-gray-700 dark:text-gray-300">
        <p>
          예약금만으로 회사가 운영됩니다. 예약금은 서비스 이용요금에 포함되어 있지 않습니다. 서비스 이용요금은
